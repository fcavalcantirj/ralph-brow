# Local Ralph config for {{PROJECT_SLUG}} — MUST be git-ignored (e.g. .env*.local). chmod 600.
# Sourced by ralph.sh and ralph-continuous.sh with `set -a`.

# Provider API key for the {{CUSTOM_ENGINE}} engine (codex model_provider={{CUSTOM_PROVIDER}}
# reads the env var NAMED by env_key in ~/.codex/config.toml — never hardcode the key there).
{{CUSTOM_ENV_KEY}}=

# ── Optional knobs (uncomment to override) ──────────────────────────────────
# ENGINE=claude            # claude | codex | {{CUSTOM_ENGINE}} (the ralph-*.sh wrappers set this)
# MODEL=                   # Claude model pin (empty = Claude Code CLI default)
# CODEX_MODEL=gpt-5.6-sol
# CODEX_EFFORT=max
# CUSTOM_MODEL={{CUSTOM_MODEL}}
# CUSTOM_EFFORT=           # empty = don't send model_reasoning_effort to the provider
# RALPH_PUSH=0             # 1 = git push after each task (needs a git remote)
# BATCH_SIZE=3
# BATCH_PAUSE_MINS=15
# WAIT_TIME_MINS=15
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
